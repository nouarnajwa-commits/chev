{
  "name": "atlas-chevalon",
  "version": "8.2.0",
  "description": "Atlas Photographique \u2014 Cimenterie du Chevalon",
  "repository": {
    "type": "git",
    "url": "https://github.com/najnajwa/atlas-cimenterie-du-chevalon"
  },
  "main": "electron.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "build-mac": "electron-builder --mac"
  },
  "build": {
    "appId": "com.chevalon.atlas",
    "productName": "Atlas Chevalon",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron.js",
      "server.js",
      "public/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "public/assets",
        "to": "assets",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Atlas Chevalon"
    }
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "multer": "^2.0.0",
    "sharp": "^0.33.4"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  }
}